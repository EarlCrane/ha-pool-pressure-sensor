# Copy this file to secrets.yaml (in the same directory as your node YAML)
# and fill in your values. secrets.yaml is gitignored — never commit it.

wifi_ssid: "YourWifiNetworkName"
wifi_password: "YourWifiPassword"

# Generate with: openssl rand -base64 32
ha_api_key: "base64encodedkeyhere="

# Generate with: openssl rand -hex 16
ota_password: "hexstringhere"

# Any strong password for the fallback AP
ap_password: "FallbackHotspotPassword"
